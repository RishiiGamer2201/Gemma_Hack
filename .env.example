# Local inference only. Non-loopback URLs are rejected by the adapter.
NYAYA_OLLAMA_URL=http://127.0.0.1:11434
NYAYA_OLLAMA_MODEL=gemma4:e4b-it-q4_K_M

# Keep contexts bounded on the validated demo GPU.
NYAYA_MAX_CONTEXT_TOKENS=8192
NYAYA_MAX_OUTPUT_TOKENS=1200

# Local data paths.
NYAYA_CORPUS_PATH=data/processed/sections
NYAYA_INDEX_PATH=data/indexes
